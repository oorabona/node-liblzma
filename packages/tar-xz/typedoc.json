{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/node/file.ts"],
  "tsconfig": "./tsconfig.json",
  "out": "../../docs-site/tar-xz-api",
  "name": "tar-xz",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "navigationLinks": {
    "GitHub": "https://github.com/oorabona/node-liblzma/tree/master/packages/tar-xz",
    "npm": "https://www.npmjs.com/package/tar-xz",
    "Demo": "https://oorabona.github.io/node-liblzma/tar-xz/",
    "node-liblzma API": "https://oorabona.github.io/node-liblzma/"
  },
  "plugin": ["typedoc-material-theme"],
  "hideGenerator": true,
  "gitRevision": "master",
  "searchInComments": true,
  "searchInDocuments": true,
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "json5",
    "tsx",
    "typescript",
    "diff",
    "powershell"
  ]
}
