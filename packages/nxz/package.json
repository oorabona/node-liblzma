{
  "name": "@oorabona/nxz",
  "version": "7.0.1",
  "description": "Portable xz-like CLI tool for Node.js — compress, decompress, and handle tar.xz archives",
  "type": "module",
  "main": "./lib/nxz.js",
  "bin": {
    "nxz": "lib/nxz.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf lib",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "check": "biome check",
    "check:write": "biome check --write"
  },
  "dependencies": {
    "node-liblzma": "workspace:^",
    "tar-xz": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "lib/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oorabona/node-liblzma",
    "directory": "packages/nxz"
  },
  "keywords": [
    "xz",
    "lzma",
    "lzma2",
    "compress",
    "decompress",
    "tar",
    "tar.xz",
    "archive",
    "extract",
    "cli",
    "command-line",
    "nxz",
    "node",
    "nodejs"
  ],
  "author": "Olivier ORABONA",
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/oorabona/node-liblzma/issues"
  },
  "homepage": "https://github.com/oorabona/node-liblzma/tree/master/packages/nxz",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
